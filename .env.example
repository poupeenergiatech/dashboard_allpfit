# Postgres próprio — connection string do banco da aplicação (auth, academias, contacts,
# conversions, manual_data, pending_signatures, trained_academias, report_settings, users,
# sessions). Ver db/README.md para aplicar o schema.
DATABASE_URL=

# Supabase — mantido só para uso somente-leitura futuro (ex.: alle_documentos_clientes,
# ver src/lib/supabase/readonly.ts). Não é mais usado para auth nem para dados do
# dashboard. Obtenha em Project Settings > API no painel do Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Agregador de números WhatsApp — endpoint que retorna contatos do dia por academia
# (ver premissa do projeto). Sem essas variáveis, /api/agregador só faz no-op.
AGREGADOR_API_URL=
AGREGADOR_API_KEY=

# Protege /api/sync-alle-documentos (cron externo opcional do sync Alle Documentos) contra
# chamadas externas não autorizadas — defina o mesmo valor no serviço que dispara o cron (ver
# docs/DEPLOY.md). Sem essa variável, o endpoint roda sem checagem — aceitável só em dev.
CRON_SECRET=

# Protege POST /api/webhooks/agregador — endpoint de ENTRADA que o sistema agregador chama
# pra empurrar o lote diário de contatos novos pro dashboard. Diferente do CRON_SECRET: sem
# essa variável configurada, o endpoint recusa toda chamada (não tem fallback "sem checagem"),
# porque ele grava dados. Gere um valor aleatório e configure o mesmo no agregador.
AGREGADOR_WEBHOOK_SECRET=

# Protege POST /api/webhooks/scans — endpoint de ENTRADA que o RPA de scans de QR code chama
# 1x por dia com o total por academia. Mesmo esquema do AGREGADOR_WEBHOOK_SECRET, mas um
# segredo separado (integração diferente) — gere outro valor aleatório e configure no RPA.
SCANS_WEBHOOK_SECRET=
