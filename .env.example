# Supabase — obtenha em Project Settings > API no painel do Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Somente para uso em Server Actions / rotas administrativas (nunca expor no client)
SUPABASE_SERVICE_ROLE_KEY=

# Agregador de números WhatsApp — endpoint que retorna contatos do dia por academia
# (ver premissa do projeto). Sem essas variáveis, /api/agregador só faz no-op.
AGREGADOR_API_URL=
AGREGADOR_API_KEY=

# Protege /api/relatorio (webhook diário de novos contatos) contra chamadas externas não
# autorizadas — defina o mesmo valor no serviço que dispara o cron (ver docs/DEPLOY.md).
# Sem essa variável, o endpoint roda sem checagem — aceitável só em dev.
CRON_SECRET=

# Protege POST /api/webhooks/agregador — endpoint de ENTRADA que o sistema agregador chama
# pra empurrar o lote diário de contatos novos pro dashboard. Diferente do CRON_SECRET: sem
# essa variável configurada, o endpoint recusa toda chamada (não tem fallback "sem checagem"),
# porque ele grava dados. Gere um valor aleatório e configure o mesmo no agregador.
AGREGADOR_WEBHOOK_SECRET=
